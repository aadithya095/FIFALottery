# Supabase — get from your project settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase public anon key — safe to expose to browser (used only for health checks)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-256-bit-secret

# JWT expiry (short-lived access token)
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS — set to your deployed Netlify domain in production
ALLOWED_ORIGIN=http://localhost:3000

# Admin accounts for seed-admins.js (run once, then remove or rotate passwords)
ADMIN_USERNAME=matchday_admin
ADMIN_PASSWORD=change-me-admin-123
SUPER_ADMIN_USERNAME=host_boss
SUPER_ADMIN_PASSWORD=change-me-super-123
